# Large model provider configuration
LLM_PROVIDER=volcengine_ark
LLM_API_KEY=replace_with_your_api_key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_RESPONSES_PATH=/responses
LLM_MODEL=doubao-seed-2-0-lite-260428

# Multimodal/document extraction model
MULTIMODAL_MODEL=doubao-seed-2-0-lite-260428

# Runtime controls
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
